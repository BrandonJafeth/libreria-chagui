---
import BaseLayout from '../layouts/BaseLayout.astro'
import PageHero from '../components/sections/PageHero.astro'
import CtaBanner from '../components/sections/CtaBanner.astro'
import CatalogFilters from '../components/islands/CatalogFilters'
import { getProducts, getTipos } from '../lib/products'
import { site } from '../data/site'

const products = await getProducts()
const tipos = await getTipos()

const tipoParam = Astro.url.searchParams.get('tipo')
const initialTipo = tipoParam && tipos.includes(tipoParam) ? tipoParam : 'Todos'
---

<BaseLayout
  title="Catálogo de Productos en Hatillo, San José"
  description="Catálogo de Librería y Bazar Chagui en Hatillo, San José. Útiles escolares, artículos de oficina, tecnología y más. Consultá disponibilidad por WhatsApp."
  keywords="útiles escolares San José, artículos de oficina Hatillo, tecnología Hatillo, cuadernos San José, lapiceros Hatillo, papelería San José Costa Rica"
>
  <PageHero
    eyebrow="Nuestro catálogo"
    heading="Todo lo que necesitás, en un solo lugar"
    subtext="Explorá nuestros productos por categoría. ¿No ves lo que buscás? Escríbenos por WhatsApp y con gusto te ayudamos."
    breadcrumb="Catálogo"
    image="https://res.cloudinary.com/daqragn9m/image/upload/v1781921501/libreria-chagui-catalogo_ixpkqa.jpg"
    imageAlt="Productos de Librería Chagui"
  />

  <section class="bg-background py-10 md:py-16 px-6 pb-20">
    <div class="max-w-6xl mx-auto">
      <CatalogFilters
        products={products}
        tipos={tipos}
        initialTipo={initialTipo}
        client:visible
      />
    </div>
  </section>

  <section class="bg-background border-t border-foreground/5 py-10 px-6">
    <div class="max-w-6xl mx-auto">
      <p class="text-[11px] font-semibold tracking-[0.2em] uppercase text-foreground/35 mb-5">
        Índice de productos
      </p>
      <ul class="columns-2 sm:columns-3 lg:columns-4 gap-x-8">
        {products.map(p => (
          <li class="mb-2">
            <a
              href={`/producto/${p.slug}`}
              class="text-sm text-foreground/55 hover:text-foreground transition-colors leading-snug"
            >
              {p.nombre}
            </a>
          </li>
        ))}
      </ul>
    </div>
  </section>

  <CtaBanner
    eyebrow="¿Buscás algo en especial?"
    heading="Escríbenos por WhatsApp y con gusto te ayudamos"
    subtext="Si no encontrás un producto en el catálogo, consultanos directo por WhatsApp."
    buttonLabel="Consultar por WhatsApp"
    buttonHref={site.contact.whatsappBase}
    external={true}
  />
</BaseLayout>
