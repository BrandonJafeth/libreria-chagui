---
import BaseLayout from '../layouts/BaseLayout.astro'
import PageHero from '../components/sections/PageHero.astro'
import ServicesGrid from '../components/sections/ServicesGrid.astro'
import CtaBanner from '../components/sections/CtaBanner.astro'
import { serviceGroups } from '../data/services'
import { site } from '../data/site'

const allServices = serviceGroups.flatMap(g => g.servicios)
const serviceListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Servicios de Librería y Bazar Chagui',
  url: `${site.domain}/servicios`,
  itemListElement: allServices.map((s, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'Service',
      name: s.nombre,
      description: s.descripcion,
      provider: { '@type': 'LocalBusiness', name: site.name },
      areaServed: { '@type': 'City', name: 'Hatillo, San José' },
      url: `${site.domain}/servicios`,
    },
  })),
}
---

<BaseLayout
  title="Servicios de Impresión, Sublimación y Fotografía en Hatillo"
  description="Impresión de documentos y fotos, copias, sublimación de camisetas y tazas, diseño gráfico y fotografía tipo pasaporte en Hatillo, San José. Cotizá por WhatsApp."
  keywords="impresión Hatillo, copias San José, sublimación camisetas San José, diseño gráfico Hatillo, fotografía pasaporte San José, impresión documentos Hatillo Costa Rica"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(serviceListSchema)} />
  </Fragment>
  <section class="relative">
    <div class="absolute inset-0 cuaderno-bg pointer-events-none" aria-hidden="true"></div>
    <div class="relative z-10">
      <PageHero
        eyebrow="Nuestros servicios"
        heading="Más que una librería"
        subtext="Impresión, sublimación, diseño y fotografía con la misma atención cercana de siempre. Consultá por WhatsApp y con gusto te cotizamos."
        breadcrumb="Servicios"
        image="https://res.cloudinary.com/daqragn9m/image/upload/v1782083176/libreria-chagui-impresion_lvbn9r.jpg"
        imageAlt="Servicios de Librería y Bazar Chagui"
      />

      <ServicesGrid groups={serviceGroups} />
    </div>
  </section>

  <CtaBanner
    eyebrow="También tenemos productos"
    heading="Mirá nuestro catálogo"
    subtext="Además de servicios, tenemos útiles escolares, artículos de oficina, tecnología y más. Todo en un solo lugar."
    buttonLabel="Ver catálogo"
    buttonHref="/catalogo"
    buttonIcon="arrow"
  />
</BaseLayout>
