---
import BaseLayout from '../layouts/BaseLayout.astro'
import HeroHome from '../components/sections/HeroHome.astro'
import FeaturesGrid from '../components/sections/FeaturesGrid.astro'
import BentoHomeServices from '../components/sections/BentoHomeServices.astro'
import CtaBanner from '../components/sections/CtaBanner.astro'
import { supabase } from '../lib/supabase'
import { formatPrice } from '../lib/format'
import { serviceGroups } from '../data/services'
import type { FeatureCard } from '../components/sections/FeaturesGrid.astro'

const { data: destacados } = await supabase
  .from('products')
  .select('id, slug, nombre, precio, product_images(url, es_principal, alt)')
  .eq('destacado', true)
  .eq('estado', 'disponible')
  .order('updated_at', { ascending: false })
  .limit(12)

const mainImage = (p: any) =>
  p.product_images?.find((i: any) => i.es_principal) ?? p.product_images?.[0] ?? null

// Build service items with their category color configs for the bento grid
const svcConfig: Record<string, { accent: string; tint: string; imagen: string }> = {
  'imp-1': { accent: '#2E5C8A', tint: 'rgba(46,92,138,0.09)',  imagen: 'https://res.cloudinary.com/daqragn9m/image/upload/v1782083176/libreria-chagui-impresion_lvbn9r.jpg' },
  'sub-1': { accent: '#C0392B', tint: 'rgba(192,57,43,0.09)',  imagen: 'https://res.cloudinary.com/daqragn9m/image/upload/v1781919412/libreria-chagui-sublimacion_qnpjju.jpg' },
  'dis-1': { accent: '#B87C20', tint: 'rgba(232,163,61,0.11)', imagen: 'https://res.cloudinary.com/daqragn9m/image/upload/v1781919585/libreria-chagui-tarjetas-de-presentacion_osklxc.jpg' },
  'fot-1': { accent: '#4A5568', tint: 'rgba(74,85,104,0.08)',  imagen: 'https://res.cloudinary.com/daqragn9m/image/upload/v1781919651/libreria-chagui-foto-pasaporte_t7d0ms.jpg' },
}
const bentoServices = serviceGroups
  .flatMap(g => g.servicios)
  .filter(s => ['imp-1', 'sub-1', 'dis-1', 'fot-1'].includes(s.id))
  .map(s => ({ ...s, ...svcConfig[s.id]! }))

// icon = nombre Ant Design sin "ant-design:" y sin "-outlined" (FeaturesGrid los agrega)
const categoryCards: FeatureCard[] = [
  {
    icon: 'read',
    image: 'https://res.cloudinary.com/daqragn9m/image/upload/v1781889185/productos-escolares_ku9skf.jpg',
    title: 'Escolar',
    text: 'Cuadernos, lápices, mochilas y todo para el cole.',
    href: '/catalogo?tipo=Escolar',
    iconColor: 'accent-2',
  },
  {
    icon: 'file-text',
    image: 'https://res.cloudinary.com/daqragn9m/image/upload/v1781889185/productos-oficina_w17o35.jpg',
    title: 'Oficina',
    text: 'Artículos de papelería y oficina para tu día a día.',
    href: '/catalogo?tipo=Oficina',
    iconColor: 'foreground',
  },
  {
    icon: 'laptop',
    image: 'https://res.cloudinary.com/daqragn9m/image/upload/v1781889187/productos-tecnologia_a252jo.jpg',
    title: 'Tecnología',
    text: 'Accesorios y artículos de tecnología.',
    href: '/catalogo?tipo=Tecnología',
    iconColor: 'accent-3',
  },
  {
    icon: 'tool',
    image: 'https://res.cloudinary.com/daqragn9m/image/upload/v1782083176/libreria-chagui-impresion_lvbn9r.jpg',
    title: 'Servicios',
    text: 'Impresión, sublimación, diseño y fotografía.',
    href: '/servicios',
    iconColor: 'accent',
  },
]
---

<BaseLayout
  title="Inicio"
  description="Librería y Bazar Chagui en Hatillo, San José. Útiles escolares, artículos de oficina y tecnología. Impresión, copias, sublimación, diseño y fotografía. Diagonal al C.C. Plaza América."
  keywords="librería Hatillo, librería San José, papelería San José, útiles escolares Hatillo, impresión San José, bazar San José, librería bazar Costa Rica, papelería Hatillo"
>
  <HeroHome
    badgeInner="Chagui"
    badgeText="Librería y bazar en Hatillo"
    heading={`Todo para la escuela,\nla papelería y tu creatividad`}
    subtext="La forma más rápida de contactarnos es por WhatsApp. También nos encontrás en nuestras redes sociales o visitándonos en nuestra tienda en Hatillo."
    ctaPrimary={{ label: 'Ver catálogo', href: '/catalogo' }}
    ctaSecondary={{ label: 'Ver servicios', href: '/servicios' }}
  />

  <FeaturesGrid
    heading="Comprá por categoría"
    subtext="Encontrá rápido lo que necesitás."
    cards={categoryCards}
  />

  {destacados && destacados.length > 0 && (
    <section class="bg-background py-16 md:py-20">
      <div class="max-w-6xl mx-auto px-6">

        <!-- Header -->
        <div class="flex items-end justify-between mb-8 reveal">
          <div>
            <p class="text-xs font-body font-semibold uppercase tracking-[0.2em] text-foreground/40 mb-1.5">Destacados</p>
            <h2 class="font-heading font-bold text-2xl md:text-3xl text-foreground">Productos destacados</h2>
            <p class="font-body text-foreground/55 text-sm mt-1.5">Algunos de nuestros favoritos.</p>
          </div>
          <a
            href="/catalogo"
            class="hidden sm:inline-flex items-center gap-1.5 text-accent font-body font-semibold text-[13px] uppercase tracking-[0.12em] hover:opacity-75 transition-opacity"
          >
            Ver catálogo
            <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </a>
        </div>

        <!-- Carousel -->
        <div class="carousel-wrapper">
          <button class="carousel-arrow carousel-arrow--prev" aria-label="Anterior">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m15 18-6-6 6-6"/></svg>
          </button>

          <blossom-carousel id="destacados-carousel" class="carousel">
            {destacados.map((p: any) => {
              const img = mainImage(p)
              return (
                <a href={`/producto/${p.slug}`} class="slide">
                  <div class="h-1 w-full" style="background: hsl(6 63% 46%)"></div>
                  <div class="slide-img">
                    {img
                      ? <img src={img.url} alt={img.alt ?? p.nombre} loading="lazy" width="400" height="400" />
                      : <div class="slide-placeholder"><span>{p.nombre.charAt(0).toUpperCase()}</span></div>
                    }
                  </div>
                  <div class="slide-info">
                    <p class="slide-nombre">{p.nombre}</p>
                    <p class="slide-precio">{formatPrice(p.precio)}</p>
                  </div>
                </a>
              )
            })}
          </blossom-carousel>

          <button class="carousel-arrow carousel-arrow--next" aria-label="Siguiente">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
          </button>
        </div>

        <div class="carousel-dots" id="carousel-dots"></div>

        <div class="text-center mt-6 sm:hidden">
          <a href="/catalogo" class="text-accent font-body font-semibold text-[13px] uppercase tracking-[0.12em] hover:opacity-75 transition-opacity">
            Ver todo el catálogo →
          </a>
        </div>

      </div>
    </section>
  )}

  <BentoHomeServices
    heading="Nuestros servicios"
    subtext="Además de productos, ofrecemos impresión, sublimación, diseño y fotografía."
    items={bentoServices}
  />

  <CtaBanner
    eyebrow="Todo en un solo lugar"
    heading="Explorá el catálogo completo"
    subtext="Útiles escolares, artículos de oficina, tecnología, manualidades y más. Todo lo que necesitás, disponible en tienda."
    buttonLabel="Ver catálogo"
    buttonHref="/catalogo"
    buttonIcon="arrow"
  />
</BaseLayout>

<style is:global>
  .carousel-wrapper {
    position: relative;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }

  blossom-carousel.carousel {
    display: grid;
    grid-auto-flow: column;
    grid-auto-columns: clamp(180px, 26vw, 260px);
    gap: 1rem;
    overflow-x: auto;
    scroll-snap-type: x mandatory;
    scrollbar-width: none;
    flex: 1;
  }
  blossom-carousel.carousel::-webkit-scrollbar { display: none; }

  .slide {
    scroll-snap-align: start;
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: inherit;
    border-radius: 12px;
    overflow: hidden;
    background: white;
    border: 1px solid rgba(43,43,43,0.07);
    box-shadow: 0 1px 4px rgba(0,0,0,0.04), 0 4px 16px rgba(0,0,0,0.03);
    transition: transform 0.22s, box-shadow 0.22s;
  }
  .slide:hover {
    transform: translateY(-2px);
    box-shadow: 0 4px 20px rgba(0,0,0,0.1);
  }

  .slide-img {
    aspect-ratio: 1;
    overflow: hidden;
    background: hsl(37 33% 96%);
  }
  .slide-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s;
  }
  .slide:hover .slide-img img { transform: scale(1.04); }

  .slide-placeholder {
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, hsl(37 33% 93%), hsl(37 33% 87%));
    display: flex;
    align-items: center;
    justify-content: center;
  }
  .slide-placeholder span {
    font-size: 3.5rem;
    font-weight: 900;
    line-height: 1;
    color: rgba(0,0,0,0.06);
    font-family: Poppins, sans-serif;
    user-select: none;
  }

  .slide-info { padding: 0.875rem; }
  .slide-nombre {
    font-size: 0.875rem;
    font-weight: 500;
    margin: 0 0 0.3rem;
    line-height: 1.35;
    color: hsl(0 0% 17%);
    font-family: Poppins, sans-serif;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .slide-precio {
    font-size: 1rem;
    font-weight: 700;
    color: hsl(6 63% 46%);
    margin: 0;
    font-family: Poppins, sans-serif;
  }

  .carousel-arrow {
    flex-shrink: 0;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    border: 1px solid rgba(43,43,43,0.12);
    background: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    box-shadow: 0 2px 8px rgba(0,0,0,0.08);
    color: hsl(0 0% 17%);
    transition: background 0.15s;
  }
  .carousel-arrow:hover { background: hsl(37 33% 96%); }

  @media (max-width: 640px) { .carousel-arrow { display: none; } }

  .carousel-dots {
    display: flex;
    justify-content: center;
    gap: 6px;
    margin-top: 1.25rem;
  }
  .carousel-dots button {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    border: none;
    background: rgba(43,43,43,0.2);
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, width 0.2s, border-radius 0.2s;
  }
  .carousel-dots button.active {
    background: hsl(6 63% 46%);
    width: 20px;
    border-radius: 3px;
  }
</style>

<script>
  import '@blossom-carousel/web'

  const carousel = document.getElementById('destacados-carousel') as HTMLElement | null
  const dotsContainer = document.getElementById('carousel-dots') as HTMLElement | null
  const prevBtn = document.querySelector('.carousel-arrow--prev') as HTMLElement | null
  const nextBtn = document.querySelector('.carousel-arrow--next') as HTMLElement | null

  if (carousel && dotsContainer) {
    const origSlides = Array.from(carousel.querySelectorAll('.slide')) as HTMLElement[]
    const n = origSlides.length

    // Clone for infinite loop: [clones-of-end][originals][clones-of-start]
    if (n > 1) {
      origSlides.slice().reverse().forEach(s => {
        const c = s.cloneNode(true) as HTMLElement
        c.setAttribute('aria-hidden', 'true')
        c.setAttribute('tabindex', '-1')
        carousel.insertBefore(c, carousel.firstChild)
      })
      origSlides.forEach(s => {
        const c = s.cloneNode(true) as HTMLElement
        c.setAttribute('aria-hidden', 'true')
        c.setAttribute('tabindex', '-1')
        carousel.appendChild(c)
      })
    }

    // Slide pitch = element width + column-gap
    const slideWidth = () => {
      const el = carousel.querySelector('.slide') as HTMLElement
      if (!el) return 260
      const gapStr = getComputedStyle(carousel).columnGap
      const gap = gapStr && gapStr !== 'normal' ? parseFloat(gapStr) : 0
      return el.getBoundingClientRect().width + gap
    }

    // Silent jump: disable snap → set position → restore snap
    const silentJump = (pos: number) => {
      carousel.style.scrollSnapType = 'none'
      carousel.scrollLeft = pos
      requestAnimationFrame(() => requestAnimationFrame(() => {
        carousel.style.scrollSnapType = ''
      }))
    }

    // Start at first real slide
    if (n > 1) setTimeout(() => silentJump(slideWidth() * n), 0)

    // Build dots
    origSlides.forEach((_, i) => {
      const btn = document.createElement('button')
      btn.setAttribute('aria-label', `Ir a slide ${i + 1}`)
      if (i === 0) btn.classList.add('active')
      btn.addEventListener('click', () => {
        const target = n > 1 ? slideWidth() * (n + i) : slideWidth() * i
        carousel.scrollTo({ left: target, behavior: 'smooth' })
      })
      dotsContainer.appendChild(btn)
    })
    const dots = Array.from(dotsContainer.querySelectorAll('button'))

    const updateDots = (scrollLeft: number) => {
      const sw = slideWidth()
      const rawIdx = Math.round(scrollLeft / sw)
      const realIdx = n > 1 ? ((rawIdx - n) % n + n) % n : rawIdx
      dots.forEach((d, i) => d.classList.toggle('active', i === realIdx))
    }

    // Scroll: update dots + wrap position when in clone zone
    let scrollTimer: ReturnType<typeof setTimeout>
    let jumping = false

    carousel.addEventListener('scroll', () => {
      if (jumping) return
      updateDots(carousel.scrollLeft)
      if (n <= 1) return
      clearTimeout(scrollTimer)
      scrollTimer = setTimeout(() => {
        const sw = slideWidth()
        const idx = Math.round(carousel.scrollLeft / sw)
        if (idx < n) {
          jumping = true
          silentJump(sw * (idx + n))
          setTimeout(() => { jumping = false }, 60)
        } else if (idx >= n * 2) {
          jumping = true
          silentJump(sw * (idx - n))
          setTimeout(() => { jumping = false }, 60)
        }
      }, 200)
    }, { passive: true })

    // Arrow buttons
    prevBtn?.addEventListener('click', () => {
      carousel.scrollBy({ left: -slideWidth(), behavior: 'smooth' })
    })
    nextBtn?.addEventListener('click', () => {
      carousel.scrollBy({ left: slideWidth(), behavior: 'smooth' })
    })

    // Autoplay — pauses on interaction
    let userInteracted = false
    carousel.addEventListener('pointerdown', () => { userInteracted = true })
    carousel.addEventListener('touchstart', () => { userInteracted = true }, { passive: true })

    setInterval(() => {
      if (userInteracted) { userInteracted = false; return }
      carousel.scrollBy({ left: slideWidth(), behavior: 'smooth' })
    }, 4000)
  }
</script>
