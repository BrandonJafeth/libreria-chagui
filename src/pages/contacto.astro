---
import BaseLayout from '../layouts/BaseLayout.astro'
import PageHero from '../components/sections/PageHero.astro'
import { site } from '../data/site'
---

<BaseLayout
  title="Contacto"
  description="Contactá a Librería y Bazar Chagui por WhatsApp o redes sociales. Estamos para ayudarte."
>
  <PageHero
    eyebrow="Contacto"
    heading="Hablemos"
    subtext="La forma más rápida de contactarnos es por WhatsApp. También nos encontrás en redes o pasando por la tienda en Hatillo."
    breadcrumb="Contacto"
  />

  <section class="bg-background py-16 md:py-24 px-6">
    <div class="max-w-3xl mx-auto text-center">

      <!-- WhatsApp CTA -->
      <div class="reveal mb-12">
        <a
          href={site.contact.whatsappBase}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-accent text-white rounded-full px-8 py-4 inline-flex items-center gap-2 font-body font-semibold text-base uppercase tracking-wider hover:opacity-90 transition-opacity"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          Escribir por WhatsApp
        </a>
      </div>

      <!-- Contact info -->
      <div class="reveal flex flex-col gap-5 items-center" style="--d: 0.15s">
        <!-- Address -->
        <div class="flex items-start gap-3 max-w-sm">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 mt-0.5 text-accent-2" aria-hidden="true">
            <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          <p class="text-foreground/60 text-sm leading-relaxed text-left">{site.contact.address}</p>
        </div>

        <!-- Phone -->
        <div class="flex items-center gap-3">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-accent-2" aria-hidden="true">
            <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 14.4a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 4h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 11a16 16 0 0 0 6 6l.82-.82a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 18.5z"/>
          </svg>
          <a href={`tel:${site.contact.phone}`} class="text-foreground/60 text-sm hover:text-foreground transition-colors">
            {site.contact.phone}
          </a>
        </div>

        <!-- Social -->
        <div class="flex items-center gap-4 mt-2">
          <a href={site.social.instagram} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-foreground/55 hover:text-foreground transition-colors" aria-label="Instagram">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><rect width="20" height="20" x="2" y="2" rx="5" ry="5"/><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/><line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/></svg>
            Instagram
          </a>
          <a href={site.social.facebook} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-foreground/55 hover:text-foreground transition-colors" aria-label="Facebook">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/></svg>
            Facebook
          </a>
          <a href={site.social.tiktok} target="_blank" rel="noopener noreferrer" class="flex items-center gap-2 text-sm text-foreground/55 hover:text-foreground transition-colors" aria-label="TikTok">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/></svg>
            TikTok
          </a>
        </div>
      </div>

      <!-- Google Maps embed placeholder -->
      <!-- TODO: reemplazar con embed real de Google Maps de Hatillo / Plaza América -->
      <div class="reveal mt-12 rounded-2xl overflow-hidden bg-card border border-foreground/8 h-64 flex items-center justify-center" style="--d: 0.25s">
        <div class="text-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-accent-2/40 mx-auto mb-3" aria-hidden="true"><path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/></svg>
          <p class="text-xs text-foreground/30">Mapa · Hatillo, de la rotonda 75m norte</p>
          <p class="text-xs text-foreground/20 mt-1">TODO: pegar iframe de Google Maps</p>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
