---
import BaseLayout from '../layouts/BaseLayout.astro'
import PageHero from '../components/sections/PageHero.astro'
import CtaBanner from '../components/sections/CtaBanner.astro'
import { site } from '../data/site'

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  name: `Contacto — ${site.name}`,
  url: `${site.domain}/contacto`,
  description: 'Contactá a Librería y Bazar Chagui en Hatillo, San José. Horario de atención, dirección y consultas por WhatsApp.',
  mainEntity: {
    '@type': 'LocalBusiness',
    name: site.name,
    telephone: `+${site.contact.whatsapp}`,
    address: {
      '@type': 'PostalAddress',
      streetAddress: 'Hatillo, de la rotonda 75 metros norte, mano derecha',
      addressLocality: 'Hatillo',
      addressRegion: 'San José',
      addressCountry: 'CR',
    },
    openingHoursSpecification: [
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday'],
        opens: '08:00',
        closes: '19:00',
      },
      {
        '@type': 'OpeningHoursSpecification',
        dayOfWeek: ['Saturday'],
        opens: '09:00',
        closes: '18:00',
      },
    ],
    url: site.domain,
  },
}
---

<BaseLayout
  title="Contacto y Ubicación | Librería Chagui Hatillo"
  description="Contactá a Librería y Bazar Chagui en Hatillo, San José. De la rotonda 75 m norte. Lun–Vie 8–19h, Sáb 9–18h. WhatsApp: +506 6359-5383."
  keywords="contacto librería Hatillo, dirección Chagui, teléfono librería San José, horario Hatillo Costa Rica"
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(contactSchema)} />
  </Fragment>

  <PageHero
    eyebrow="Contacto"
    heading="Encuéntranos en Hatillo"
    subtext="Estamos para atenderte en local o por WhatsApp. Consultas sobre productos, disponibilidad y servicios."
    breadcrumb="Contacto"
    image="https://res.cloudinary.com/daqragn9m/image/upload/v1782085471/libreria-chagui-nosotros_x3qmb5.png"
    imageAlt="Vista de Hatillo, San José, Costa Rica"
  />

  <section class="bg-background py-16 md:py-24 px-6">
    <div class="max-w-5xl mx-auto">
      <div class="grid md:grid-cols-2 gap-10 lg:gap-16">

        <!-- NAP + Hours -->
        <div class="reveal">
          <h2
            class="font-heading font-black text-foreground mb-8"
            style="font-size: clamp(1.5rem, 3vw, 2rem);"
          >
            Información de contacto
          </h2>

          <ul class="flex flex-col gap-7">

            <!-- Address -->
            <li class="flex gap-4">
              <div
                class="shrink-0 w-9 h-9 flex items-center justify-center"
                style="background: rgba(46,92,138,0.08);"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     class="text-accent-2" aria-hidden="true">
                  <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
                  <circle cx="12" cy="10" r="3"/>
                </svg>
              </div>
              <div>
                <p class="text-[11px] font-semibold tracking-[0.18em] uppercase text-foreground/40 mb-1.5">
                  Dirección
                </p>
                <p class="font-body text-foreground/75 leading-relaxed text-sm">
                  {site.contact.address}
                </p>
                <a
                  href={site.contact.mapsUrl}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="mt-2 inline-flex items-center gap-1.5 text-[0.68rem] font-bold tracking-[0.16em] uppercase text-accent-2 hover:opacity-70 transition-opacity"
                >
                  Ver en Google Maps
                  <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10"
                       viewBox="0 0 24 24" fill="none" stroke="currentColor"
                       stroke-width="2.5" aria-hidden="true">
                    <path d="m9 18 6-6-6-6"/>
                  </svg>
                </a>
              </div>
            </li>

            <!-- Phone -->
            <li class="flex gap-4">
              <div
                class="shrink-0 w-9 h-9 flex items-center justify-center"
                style="background: rgba(46,92,138,0.08);"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     class="text-accent-2" aria-hidden="true">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 14.4a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 4h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 11a16 16 0 0 0 6 6l.82-.82a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 18.5z"/>
                </svg>
              </div>
              <div>
                <p class="text-[11px] font-semibold tracking-[0.18em] uppercase text-foreground/40 mb-1.5">
                  Teléfono / WhatsApp
                </p>
                <a
                  href={`tel:${site.contact.phone}`}
                  class="font-body text-foreground/75 hover:text-foreground transition-colors text-sm block"
                >
                  {site.contact.phone}
                </a>
                <a
                  href={`tel:${site.contact.phone2}`}
                  class="font-body text-foreground/75 hover:text-foreground transition-colors text-sm block mt-1"
                >
                  {site.contact.phone2} <span class="text-foreground/40 text-[11px]">Fijo</span>
                </a>
              </div>
            </li>

            <!-- Hours -->
            <li class="flex gap-4">
              <div
                class="shrink-0 w-9 h-9 flex items-center justify-center"
                style="background: rgba(46,92,138,0.08);"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2" stroke-linecap="round" stroke-linejoin="round"
                     class="text-accent-2" aria-hidden="true">
                  <circle cx="12" cy="12" r="10"/>
                  <polyline points="12 6 12 12 16 14"/>
                </svg>
              </div>
              <div>
                <p class="text-[11px] font-semibold tracking-[0.18em] uppercase text-foreground/40 mb-1.5">
                  Horario
                </p>
                <ul class="flex flex-col gap-1 font-body text-sm text-foreground/75">
                  <li>{site.hours.weekdays.label}</li>
                  <li>{site.hours.saturday.label}</li>
                  <li class="text-foreground/40">{site.hours.sunday.label}</li>
                </ul>
              </div>
            </li>

          </ul>
        </div>

        <!-- WhatsApp CTA card -->
        <div class="reveal" style="--d: 0.1s">
          <div class="bg-card border border-foreground/6 p-8 flex flex-col gap-6 h-full">
            <div>
              <p class="text-[0.62rem] font-semibold tracking-[0.22em] uppercase text-accent mb-3">
                Consultas rápidas
              </p>
              <h3
                class="font-heading font-black text-foreground leading-tight mb-4"
                style="font-size: clamp(1.25rem, 2.5vw, 1.6rem);"
              >
                Escríbenos por WhatsApp
              </h3>
              <p class="font-body text-sm text-foreground/60 leading-relaxed">
                Respondemos preguntas sobre productos, disponibilidad, precios y servicios en horario comercial.
              </p>
            </div>
            <div>
              <a
                href={site.contact.whatsappBase}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-3 px-6 py-3.5
                       font-body font-bold text-[0.72rem] tracking-[0.18em] uppercase
                       bg-accent text-white hover:opacity-90 active:scale-[0.98]
                       transition-all duration-150"
              >
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14"
                     viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                  <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                </svg>
                Consultar ahora
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Map embed -->
      <div class="mt-14 reveal" style="--d: 0.15s; border: 1px solid rgba(43,43,43,0.08); overflow: hidden;">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3930.265640183685!2d-84.10121512520762!3d9.911819990189127!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8fa0e39ad3e12521%3A0xd88ddc26ab6162e!2sLibrer%C3%ADa%20Chagui!5e0!3m2!1ses!2scr!4v1781912155775!5m2!1ses!2scr"
          width="100%"
          height="380"
          style="border:0; display:block;"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Ubicación Librería Chagui en Google Maps"
        />
      </div>

    </div>
  </section>

  <CtaBanner
    eyebrow="¿Necesitás algo más?"
    heading="Mirá nuestro catálogo"
    subtext="Útiles escolares, artículos de oficina, tecnología y más. Todo disponible en local."
    buttonLabel="Ver catálogo"
    buttonHref="/catalogo"
    buttonIcon="arrow"
  />
</BaseLayout>
