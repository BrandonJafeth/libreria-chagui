---
import BaseLayout from '../../layouts/BaseLayout.astro'
import ProductCard from '../../components/ui/ProductCard.astro'
import CtaBanner from '../../components/sections/CtaBanner.astro'
import ProductGallery from '../../components/islands/ProductGallery'
import VariantSelector from '../../components/islands/VariantSelector'
import { getProductBySlug, getRelated } from '../../lib/products'
import { formatPrice } from '../../lib/format'
import { site } from '../../data/site'
import { supabase } from '../../lib/supabase'
import ReviewForm from '../../components/islands/ReviewForm'
import ReviewList from '../../components/sections/ReviewList.astro'

const { slug } = Astro.params
const product = await getProductBySlug(slug!)
if (!product) return Astro.redirect('/404')

const related = await getRelated(product, 4)

type ReviewRow = {
  id: string
  author_name: string
  rating: number
  comment: string | null
  created_at: string
}

const { data: reviewsRaw } = await supabase
  .from('product_reviews')
  .select('id, author_name, rating, comment, created_at')
  .eq('product_id', product.id)
  .eq('approved', true)
  .order('created_at', { ascending: false })

const reviewList = (reviewsRaw ?? []) as ReviewRow[]
const avg = reviewList.length
  ? (reviewList.reduce((s, r) => s + r.rating, 0) / reviewList.length).toFixed(1)
  : null

const ogImage = product.imagenes[0] && !product.imagenes[0].includes('PLACEHOLDER')
  ? product.imagenes[0]
  : undefined

function stripHtml(html: string): string {
  return html.replace(/<[^>]+>/g, ' ').replace(/\s+/g, ' ').trim()
}
const plainDesc = stripHtml(product.descripcion)
const descSeo   = plainDesc.slice(0, 155)
const descShort = plainDesc.slice(0, 220)

const priceValidUntil = new Date(new Date().setFullYear(new Date().getFullYear() + 1))
  .toISOString().split('T')[0]

const productSchema = {
  '@context': 'https://schema.org',
  '@type': 'Product',
  name: product.nombre,
  description: plainDesc || product.nombre,
  image: product.imagenes.filter(u => !u.includes('PLACEHOLDER')),
  sku: product.id,
  brand: { '@type': 'Brand', name: 'Librería y Bazar Chagui' },
  ...(avg ? {
    aggregateRating: {
      '@type': 'AggregateRating',
      ratingValue: avg,
      reviewCount: String(reviewList.length),
      bestRating: '5',
      worstRating: '1',
    },
    review: reviewList.map(r => ({
      '@type': 'Review',
      author: { '@type': 'Person', name: r.author_name },
      reviewRating: { '@type': 'Rating', ratingValue: String(r.rating) },
      ...(r.comment ? { reviewBody: r.comment } : {}),
    })),
  } : {}),
  offers: {
    '@type': 'Offer',
    price: product.precio,
    priceCurrency: 'CRC',
    priceValidUntil,
    availability: product.estado === 'disponible'
      ? 'https://schema.org/InStock'
      : 'https://schema.org/OutOfStock',
    url: `https://libreriafchagui.com/producto/${product.slug}`,
    seller: { '@type': 'Organization', name: 'Librería y Bazar Chagui' },
    hasMerchantReturnPolicy: {
      '@type': 'MerchantReturnPolicy',
      applicableCountry: 'CR',
      returnPolicyCategory: 'https://schema.org/MerchantReturnNotPermitted',
    },
    shippingDetails: {
      '@type': 'OfferShippingDetails',
      shippingRate: { '@type': 'MonetaryAmount', value: '0', currency: 'CRC' },
      shippingDestination: { '@type': 'DefinedRegion', addressCountry: 'CR' },
      deliveryTime: {
        '@type': 'ShippingDeliveryTime',
        handlingTime: { '@type': 'QuantitativeValue', minValue: 0, maxValue: 0, unitCode: 'DAY' },
        transitTime: { '@type': 'QuantitativeValue', minValue: 0, maxValue: 0, unitCode: 'DAY' },
      },
    },
  },
}
---

<BaseLayout
  title={product.nombre}
  description={descSeo}
  ogImage={ogImage}
>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={JSON.stringify(productSchema)} />
  </Fragment>
  <!-- Product Detail -->
  <section class="bg-background pt-32 pb-16 md:pt-40 md:pb-20 px-6">
    <div class="max-w-6xl mx-auto">
      <!-- Breadcrumb -->
      <nav aria-label="Breadcrumb" class="mb-6 md:mb-8 reveal">
        <ol class="flex flex-wrap items-center gap-1.5 text-[12px] font-body text-foreground/45">
          <li><a href="/" class="hover:text-accent transition-colors">Inicio</a></li>
          <li aria-hidden="true">/</li>
          <li><a href="/catalogo" class="hover:text-accent transition-colors">Catálogo</a></li>
          {product.tipos[0] && (
            <Fragment>
              <li aria-hidden="true">/</li>
              <li>
                <a
                  href={`/catalogo?tipo=${encodeURIComponent(product.tipos[0])}`}
                  class="hover:text-accent transition-colors"
                >
                  {product.tipos[0]}
                </a>
              </li>
            </Fragment>
          )}
          <li aria-hidden="true">/</li>
          <li class="text-foreground/70 truncate max-w-55 sm:max-w-none" aria-current="page">
            {product.nombre}
          </li>
        </ol>
      </nav>

      <div class="grid md:grid-cols-2 gap-10 lg:gap-16 items-start">

        <!-- Gallery -->
        <div class="reveal">
          <ProductGallery
            images={product.imagenes}
            alt={product.nombre}
            client:visible
          />
        </div>

        <!-- Info -->
        <div class="reveal flex flex-col" style="--d: 0.12s">
          <!-- Tipo badge -->
          <div class="flex flex-wrap gap-2 mb-4">
            {product.tipos.slice(0, 2).map((tipo) => (
              <span class="bg-accent-2/10 text-accent-2 rounded-full px-3 py-1 text-xs font-body font-medium uppercase tracking-wide">
                {tipo}
              </span>
            ))}
          </div>

          <!-- Name -->
          <h1 class="font-heading font-bold text-foreground" style="font-size: clamp(1.75rem, 4vw, 2.5rem); line-height: 1.1;">
            {product.nombre}
          </h1>

          <!-- Price -->
          <p class="font-heading text-3xl mt-4" style={`color: ${product.estado === 'agotado' ? 'rgba(43,43,43,0.4)' : 'hsl(6 63% 46%)'}`}>
            {formatPrice(product.precio)}
          </p>

          <!-- Estado -->
          <div class="flex items-center gap-2 mt-3">
            <span class="text-sm font-body font-semibold text-foreground/55 uppercase tracking-wide">Stock:</span>
            <span class={`inline-block w-2 h-2 rounded-full ${product.estado === 'disponible' ? 'bg-green-500' : 'bg-foreground/35'}`}></span>
            <span class={`text-sm font-body font-medium ${product.estado === 'disponible' ? 'text-accent-2' : 'text-foreground/60'}`}>
              {product.estado === 'disponible' ? 'Disponible' : 'Agotado'}
            </span>
          </div>

          <!-- Variant selector + CTA (island) -->
          <div class="mt-6">
            <VariantSelector product={product} client:visible />
          </div>

          <!-- Short description -->
          {descShort && (
            <p class="font-body font-light text-sm text-foreground/60 leading-relaxed mt-6">
              {descShort}
            </p>
          )}
        </div>
      </div>

      <!-- Long description -->
      {product.descripcion && (
        <div class="bg-card rounded-3xl p-8 md:p-10 mt-12 max-w-4xl mx-auto reveal">
          <h2 class="font-heading font-semibold text-xl text-foreground mb-4">Descripción</h2>
          <div class="prose" set:html={product.descripcion} />
        </div>
      )}
    </div>
  </section>

  <!-- Reviews -->
  <section class="bg-background py-16 px-6">
    <div class="max-w-4xl mx-auto">
      <div class="flex items-baseline gap-4 mb-8 reveal">
        <h2 class="font-heading font-bold text-2xl text-foreground">Reseñas</h2>
        {avg && (
          <span class="font-body text-sm text-foreground/50">
            {avg}/5 · {reviewList.length} reseña{reviewList.length !== 1 ? 's' : ''}
          </span>
        )}
      </div>

      <ReviewList reviews={reviewList} />

      <div class="mt-10">
        <ReviewForm productId={product.id} client:only="react" />
      </div>
    </div>
  </section>

  <!-- Related products -->
  {related.length > 0 && (
    <section class="bg-background py-16 px-6">
      <div class="max-w-6xl mx-auto">
        <h2 class="font-heading font-bold text-2xl text-foreground mb-8 reveal">Productos relacionados</h2>
        <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-5 md:gap-6">
          {related.map((p, i) => (
            <ProductCard product={p} delay={i * 0.08} />
          ))}
        </div>
      </div>
    </section>
  )}

  <CtaBanner
    eyebrow="¿Necesitás ayuda?"
    heading="Consultar por WhatsApp"
    subtext="Escríbenos y te atendemos con gusto."
    buttonLabel="Consultar por WhatsApp"
    buttonHref={site.contact.whatsappBase}
    external={true}
  />
</BaseLayout>
