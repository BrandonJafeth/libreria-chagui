---
import { clImg } from '../lib/cloudinary'
import { site } from '../data/site'

const year = new Date().getFullYear()
---

<footer class="bg-card pt-14 pb-8 px-6 lg:px-12" style="border-top: 1px solid rgba(43,43,43,0.08);">
  <div class="max-w-6xl mx-auto">
    <div class="grid md:grid-cols-3 gap-10">

      <!-- Brand -->
      <div class="text-center md:text-left">
        <a href="/" class="inline-block mb-5">
          <img
            src={clImg(site.logo, 'h_280,f_auto,q_auto')}
            alt={site.name}
            width={420}
            height={280}
            class="h-40 md:h-24 w-auto object-contain rounded"
            loading="lazy"
            decoding="async"
          />
        </a>
        <p class="text-sm text-foreground/75 leading-relaxed max-w-xs mx-auto md:mx-0">
          Librería, bazar y servicios de impresión en Hatillo. Artículos escolares, de oficina,
          tecnología y más.
        </p>
        <div class="flex gap-3 mt-5 justify-center md:justify-start">
          <a
            href={site.social.instagram}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Instagram"
            class="liquid-glass rounded-full w-9 h-9 flex items-center justify-center text-foreground/70 hover:text-foreground transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <rect width="20" height="20" x="2" y="2" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" x2="17.51" y1="6.5" y2="6.5"/>
            </svg>
          </a>
          <a
            href={site.social.facebook}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="Facebook"
            class="liquid-glass rounded-full w-9 h-9 flex items-center justify-center text-foreground/70 hover:text-foreground transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"/>
            </svg>
          </a>
          <a
            href={site.social.tiktok}
            target="_blank"
            rel="noopener noreferrer"
            aria-label="TikTok"
            class="liquid-glass rounded-full w-9 h-9 flex items-center justify-center text-foreground/70 hover:text-foreground transition-colors"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M9 12a4 4 0 1 0 4 4V4a5 5 0 0 0 5 5"/>
            </svg>
          </a>
        </div>
      </div>

      <!-- Navigation -->
      <div>
        <p class="text-[11px] font-semibold tracking-[0.18em] uppercase text-foreground/75 mb-4">
          Navegación
        </p>
        <ul class="flex flex-col gap-2.5">
          {site.nav.map((link) => (
            <li>
              <a
                href={link.href}
                class="text-sm text-foreground/80 hover:text-foreground transition-colors"
              >
                {link.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Contact -->
      <div>
        <p class="text-[11px] font-semibold tracking-[0.18em] uppercase text-foreground/75 mb-4">
          Contacto
        </p>
        <ul class="flex flex-col gap-3">
          <li class="flex items-start gap-2 text-sm text-foreground/80">
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="mt-0.5 shrink-0 text-accent-2" aria-hidden="true">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/><circle cx="12" cy="10" r="3"/>
            </svg>
            {site.contact.address}
          </li>
          <li>
            <a
              href={`tel:${site.contact.phone}`}
              class="flex items-center gap-2 text-sm text-foreground/80 hover:text-foreground transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-accent-2" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 14.4a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 4h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 11a16 16 0 0 0 6 6l.82-.82a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 18.5z"/>
              </svg>
              {site.contact.phone}
            </a>
          </li>
          <li>
            <a
              href={`tel:${site.contact.phone2}`}
              class="flex items-center gap-2 text-sm text-foreground/80 hover:text-foreground transition-colors"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-accent-2" aria-hidden="true">
                <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 14.4a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 4h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 11a16 16 0 0 0 6 6l.82-.82a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 18.5z"/>
              </svg>
              {site.contact.phone2}
            </a>
          </li>
          <li>
            <a
              href={site.cta.href}
              target="_blank"
              rel="noopener noreferrer"
              class="inline-flex items-center gap-2 text-sm font-medium text-accent hover:opacity-80 transition-opacity"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
              </svg>
              Escribir por WhatsApp
            </a>
          </li>
        </ul>
      </div>
    </div>

    <!-- Map — lazy facade: avoids 395 KiB de Google Maps JS en carga inicial -->
    <div class="mt-10 rounded-xl overflow-hidden" style="border: 1px solid rgba(43,43,43,0.08);">
      <div
        id="map-facade"
        role="button"
        tabindex="0"
        aria-label="Ver ubicación en Google Maps (click para cargar el mapa)"
        class="relative w-full cursor-pointer group"
        style="height: 280px; background: hsl(37 33% 93%);"
      >
        <!-- Static map preview via Google Static Maps -->
        <img
          src={`https://maps.googleapis.com/maps/api/staticmap?center=9.911819,+-84.099190&zoom=16&size=800x280&markers=color:red%7C9.911819,-84.099190&style=element:geometry%7Ccolor:0xf5f0e8&style=feature:road%7Celement:geometry%7Ccolor:0xffffff&key=${import.meta.env.GOOGLE_MAPS_KEY}`}
          alt="Mapa de ubicación Librería Chagui"
          class="w-full h-full object-cover"
          width="800"
          height="280"
          loading="lazy"
          onerror="this.style.display='none'"
        />
        <!-- Overlay con botón de carga -->
        <div class="absolute inset-0 flex flex-col items-center justify-center gap-3
                    bg-foreground/[0.03] group-hover:bg-foreground/[0.07] transition-colors duration-200">
          <div class="flex items-center gap-2.5 px-5 py-2.5 rounded-full bg-background shadow-sm
                      text-[12px] font-semibold tracking-wide text-foreground/80 border border-foreground/10">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24"
                 fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path d="M20 10c0 6-8 12-8 12s-8-6-8-12a8 8 0 0 1 16 0Z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            Clic para ver el mapa interactivo
          </div>
          <p class="text-[11px] text-foreground/45">De la rotonda de Hatillo, 75 m norte</p>
        </div>
      </div>
      <!-- El iframe real se inserta aquí al hacer clic -->
      <div id="map-container" style="display:none;"></div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-6 pt-6 flex justify-between flex-wrap gap-4" style="border-top: 1px solid rgba(43,43,43,0.08);">
      <p class="text-xs text-foreground/65">© {year} Librería y Bazar Chagui</p>
    </div>
  </div>
</footer>
