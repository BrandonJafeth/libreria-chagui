---
import SectionHeader from '../ui/SectionHeader.astro'
import Icon from '../ui/Icon.astro'
import type { ServiceGroup } from '../../data/services'

interface Props {
  heading?: string
  subtext?: string
  groups: ServiceGroup[]
}
const { heading, subtext, groups } = Astro.props

const WA_BASE = 'https://api.whatsapp.com/send?phone=50663595383&text='
function serviceWA(nombre: string) {
  return WA_BASE + encodeURIComponent(`Hola buenas, me interesa el servicio de: ${nombre}`)
}

const fallbackConfig: Record<string, { accent: string; tint: string }> = {
  'Impresión':   { accent: '#2E5C8A', tint: 'rgba(46,92,138,0.09)'  },
  'Sublimación': { accent: '#C0392B', tint: 'rgba(192,57,43,0.09)'  },
  'Diseño':      { accent: '#B87C20', tint: 'rgba(232,163,61,0.11)' },
  'Fotografía':  { accent: '#4A5568', tint: 'rgba(74,85,104,0.08)'  },
  'Servicios':   { accent: '#C0392B', tint: 'rgba(192,57,43,0.09)'  },
}

function cfgFor(group: ServiceGroup) {
  const fb = fallbackConfig[group.categoria] ?? fallbackConfig['Servicios']
  return { accent: group.accent ?? fb.accent, tint: group.tint ?? fb.tint }
}

function slugify(s: string) {
  return s
    .toLowerCase()
    .normalize('NFD')
    .replace(/[\u0300-\u036f]/g, '')
    .replace(/[^a-z0-9]+/g, '-')
}

const useTabs = groups.length > 1
const totalServices = groups.reduce((acc, g) => acc + g.servicios.length, 0)

// CSS generada por categoría:
// 1. Muestra el panel cuyo radio está activo (:has del contenedor).
// 2. Pinta la label del radio activo usando el adyacente (+), sin
//    contaminar las demás labels como haría peer-checked (~).
const tabCss = groups
  .map((g) => {
    const id = slugify(g.categoria)
    const accent = cfgFor(g).accent
    return [
      `.svc-tabs:has(#svc-tab-${id}:checked) [data-panel="${id}"]{display:block}`,
      `#svc-tab-${id}:checked+label[for="svc-tab-${id}"]{background:${accent}!important;color:#fff!important;border-color:transparent!important}`,
    ].join('\n')
  })
  .join('\n')
---

<section class="bg-background py-20 md:py-28 px-6">
  <div class="max-w-5xl mx-auto">

    {heading && (
      <div class="reveal mb-14">
        <SectionHeader {heading} {subtext} />
      </div>
    )}

    {useTabs ? (
      <div class="svc-tabs reveal">
        <style set:html={tabCss} />

        <fieldset class="border-0 p-0 m-0">
          <legend class="sr-only">Categoría de servicios</legend>

          <div class="flex flex-wrap gap-2 mb-8 overflow-x-auto -mx-1 px-1 pb-1">
            {groups.map((g, gi) => {
              const id = slugify(g.categoria)
              return (
                <Fragment>
                  <input
                    type="radio"
                    name="svc-tab"
                    id={`svc-tab-${id}`}
                    class="peer sr-only"
                    checked={gi === 0}
                  />
                  <label
                    for={`svc-tab-${id}`}
                    class="svc-badge shrink-0 cursor-pointer select-none px-5 py-2.5 rounded-full font-body font-semibold text-sm border border-foreground/10 bg-card text-foreground/60 transition-all duration-300"
                    style={`--badge-accent: ${cfgFor(g).accent}`}
                  >
                    {g.categoria}
                  </label>
                </Fragment>
              )
            })}
          </div>
        </fieldset>

        <div class="svc-panels">
          {groups.map((g) => {
            const cfg = cfgFor(g)
            const id = slugify(g.categoria)
            return (
              <div class="svc-panel" data-panel={id}>

                <div
                  class="rounded-3xl p-8 md:p-10 mb-6 flex flex-col md:flex-row items-start md:items-center gap-8 md:gap-10"
                  style={`background: ${cfg.tint}`}
                >
                  <div class="flex-1">
                    <span
                      class="font-body text-[0.65rem] font-semibold tracking-[0.22em] uppercase"
                      style={`color: ${cfg.accent}`}
                    >
                      {g.categoria}
                    </span>
                    <h3 class="font-heading font-bold text-2xl md:text-3xl text-foreground mt-2 mb-3 leading-tight">
                      {g.titulo ?? g.categoria}
                    </h3>
                    {g.descripcion && (
                      <p class="font-body text-foreground/60 leading-relaxed max-w-md mb-6">
                        {g.descripcion}
                      </p>
                    )}
                    <a
                      href={serviceWA(g.categoria)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="inline-flex items-center gap-2 rounded-full px-5 py-3 font-body font-semibold text-sm text-white hover:opacity-90 active:scale-[0.98] transition-all duration-150"
                      style={`background: ${cfg.accent}`}
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                        <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
                      </svg>
                      Consultar por WhatsApp
                    </a>
                  </div>

                  <div class="hidden sm:block relative w-32 h-28 shrink-0 mx-auto md:mx-0" aria-hidden="true">
                    <div
                      class="absolute inset-0 m-auto w-16 h-16 rounded-2xl flex items-center justify-center"
                      style={`background: ${cfg.accent}1A`}
                    >
                      <Icon name={g.servicios[0]?.icono ?? 'file-text'} size={26} class="" style={`color: ${cfg.accent}`} />
                    </div>
                    {g.servicios.slice(1, 3).map((svc, i) => (
                      <div
                        class="absolute w-10 h-10 rounded-xl bg-card shadow-sm flex items-center justify-center"
                        style={`top: ${i === 0 ? '-4px' : '64%'}; ${i === 0 ? 'right: 4px' : 'left: 0'}`}
                      >
                        <Icon name={svc.icono} size={18} style={`color: ${cfg.accent}`} />
                      </div>
                    ))}
                  </div>
                </div>

                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                  {g.servicios.map((svc, si) => (
                    <a
                      href={serviceWA(svc.nombre)}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="svc-card group bg-card rounded-2xl p-6 border border-foreground/[0.06] flex flex-col gap-5 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-black/[0.07]"
                      style={`--d: ${si * 0.06}s`}
                    >
                      <div
                        class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 transition-transform duration-300 group-hover:scale-105"
                        style={`background: ${cfg.tint}`}
                      >
                        <Icon name={svc.icono} size={22} style={`color: ${cfg.accent}`} />
                      </div>

                      <div class="flex-1">
                        <h3 class="font-heading font-semibold text-[0.95rem] text-foreground leading-snug mb-2">
                          {svc.nombre}
                        </h3>
                        <p class="font-body text-sm font-light text-foreground/50 leading-relaxed">
                          {svc.descripcion}
                        </p>
                      </div>

                      <div
                        class="flex items-center gap-1.5 text-[0.65rem] font-body font-semibold tracking-[0.14em] uppercase opacity-40 group-hover:opacity-100 transition-opacity duration-200"
                        style={`color: ${cfg.accent}`}
                      >
                        Consultar por WhatsApp
                        <Icon name="chevron-right" size={11} class="group-hover:translate-x-0.5 transition-transform duration-200" />
                      </div>
                    </a>
                  ))}
                </div>
              </div>
            )
          })}
        </div>
      </div>
    ) : (
      <div class="space-y-14">
        {groups.map((group, gi) => {
          const cfg = cfgFor(group)
          return (
            <div class="reveal" style={`--d: ${gi * 0.1}s`}>
              <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {group.servicios.map((svc) => (
                  <a
                    href={serviceWA(svc.nombre)}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="group bg-card rounded-2xl p-6 border border-foreground/[0.06] flex flex-col gap-5 transition-all duration-300 hover:-translate-y-1.5 hover:shadow-xl hover:shadow-black/[0.07]"
                  >
                    <div
                      class="w-12 h-12 rounded-xl flex items-center justify-center flex-shrink-0 transition-transform duration-300 group-hover:scale-105"
                      style={`background: ${cfg.tint}`}
                    >
                      <Icon name={svc.icono} size={22} style={`color: ${cfg.accent}`} />
                    </div>

                    <div class="flex-1">
                      <h3 class="font-heading font-semibold text-[0.95rem] text-foreground leading-snug mb-2">
                        {svc.nombre}
                      </h3>
                      <p class="font-body text-sm font-light text-foreground/50 leading-relaxed">
                        {svc.descripcion}
                      </p>
                    </div>

                    <div
                      class="flex items-center gap-1.5 text-[0.65rem] font-body font-semibold tracking-[0.14em] uppercase opacity-40 group-hover:opacity-100 transition-opacity duration-200"
                      style={`color: ${cfg.accent}`}
                    >
                      Consultar por WhatsApp
                      <Icon name="chevron-right" size={11} class="group-hover:translate-x-0.5 transition-transform duration-200" />
                    </div>
                  </a>
                ))}
              </div>
            </div>
          )
        })}
      </div>
    )}

    {totalServices <= 4 && (
      <div class="reveal mt-10 pt-8 border-t border-foreground/8" style="--d: 0.3s">
        <a
          href="/servicios"
          class="inline-flex items-center gap-2 font-body font-semibold text-sm text-accent hover:opacity-75 transition-opacity uppercase tracking-wider"
        >
          Ver todos los servicios
          <Icon name="arrow-up-right" size={14} />
        </a>
      </div>
    )}

  </div>
</section>

{useTabs && (
  <script>
    const tabs = document.querySelectorAll<HTMLInputElement>('.svc-tabs input[name="svc-tab"]')

    tabs.forEach((input) => {
      input.addEventListener('change', () => {
        const id = input.id.replace('svc-tab-', '')
        const panel = document.querySelector<HTMLElement>(`.svc-panel[data-panel="${id}"]`)
        if (!panel) return

        panel.classList.remove('is-animating')
        // Forzar reflow para poder re-disparar la animación en cada cambio de tab.
        void panel.offsetWidth
        panel.classList.add('is-animating')
      })
    })
  </script>
)}

<style>
  .svc-panel {
    display: none;
  }

  .svc-badge:hover {
    box-shadow: 0 4px 20px -4px color-mix(in srgb, var(--badge-accent) 30%, transparent);
  }

  .svc-badge:active {
    scale: 0.97;
  }
</style>
