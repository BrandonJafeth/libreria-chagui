---
interface Props {
  badgeInner: string
  badgeText: string
  heading: string
  subtext: string
  ctaPrimary: { label: string; href: string }
  ctaSecondary: { label: string; href: string }
}
const { badgeInner, badgeText, heading, subtext, ctaPrimary, ctaSecondary } = Astro.props

const lines = heading.split('\n')
---

<section class="relative min-h-[90svh] overflow-hidden bg-background flex items-center">

  <!-- Cuaderno de cuadros (signature texture) -->
  <div class="absolute inset-0 cuaderno-bg pointer-events-none" aria-hidden="true"></div>

  <!-- Línea de margen — visible en md+ -->
  <div class="absolute left-[72px] lg:left-[104px] top-0 bottom-0 w-px bg-accent/18 hidden md:block" aria-hidden="true"></div>

  <!-- Color wash top-right -->
  <div
    class="absolute top-0 right-0 w-[50vw] h-[60vh] pointer-events-none"
    style="background: radial-gradient(ellipse at 80% 20%, hsl(211 50% 36% / 0.05) 0%, transparent 60%);"
    aria-hidden="true"
  ></div>

  <div class="relative z-10 w-full max-w-7xl mx-auto px-6 md:pl-28 lg:pl-36 pt-36 pb-20 md:pt-44 md:pb-28">

    <!-- Split screen: text left / image right -->
    <div class="grid lg:grid-cols-[1fr_360px] xl:grid-cols-[1fr_420px] gap-12 xl:gap-20 items-center">

      <!-- Left: text content -->
      <div class="max-w-2xl">

        <!-- Utility line badge -->
        <div class="hero-in flex items-center gap-3 mb-8 md:mb-10" style="--d: 0s">
          <div class="w-6 h-0.5 bg-accent"></div>
          <span class="font-body text-[0.62rem] tracking-[0.22em] uppercase text-foreground/40">
            {badgeInner} &nbsp;·&nbsp; {badgeText}
          </span>
        </div>

        <!-- Heading -->
        <h1
          class="hero-in font-heading font-bold text-foreground leading-[1.0] tracking-[-0.025em]"
          style="--d: 0.12s; font-size: clamp(2.8rem, 7.5vw, 5.5rem);"
        >
          {lines[0] && <span class="block">{lines[0]}</span>}
          {lines[1] && (
            <span class="block">
              {lines[1].includes('la escuela') ? (
                <><span class="text-accent">la escuela,</span></>
              ) : (
                lines[1]
              )}
            </span>
          )}
          {lines.slice(2).map(l => <span class="block">{l}</span>)}
        </h1>

        <!-- Subtext -->
        <p
          class="hero-in font-body font-light text-base md:text-lg text-foreground/55 leading-relaxed mt-7 mb-10 max-w-lg"
          style="--d: 0.42s"
        >
          {subtext}
        </p>

        <!-- CTAs -->
        <div class="hero-in flex flex-col sm:flex-row gap-4 items-start" style="--d: 0.65s">
          <a
            href={ctaPrimary.href}
            class="bg-accent text-white rounded-full px-7 py-3.5 font-body font-semibold text-sm tracking-wider uppercase inline-flex items-center gap-2 hover:opacity-90 active:scale-[0.98] transition-all duration-150"
          >
            {ctaPrimary.label}
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
          </a>
          <a
            href={ctaSecondary.href}
            target="_blank"
            rel="noopener noreferrer"
            class="rounded-full px-7 py-3.5 font-body font-semibold text-sm tracking-wider uppercase inline-flex items-center gap-2 text-foreground/75 hover:text-foreground active:scale-[0.98] transition-all duration-150 border border-foreground/12 hover:border-foreground/25"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            {ctaSecondary.label}
          </a>
        </div>
      </div>

      <!-- Right: product image — hidden on mobile -->
      <div class="hidden lg:block" aria-hidden="true">
        <div class="relative">

          <!-- Main image -->
          <div
            class="rounded-3xl overflow-hidden"
            style="aspect-ratio: 3/4; box-shadow: 0 24px 64px -16px rgba(0,0,0,0.14);"
          >
            <img
              src="https://picsum.photos/seed/libreria-chagui-store/520/693"
              alt=""
              class="w-full h-full object-cover"
              loading="eager"
              decoding="async"
            />
            <!-- Subtle brand wash -->
            <div
              class="absolute inset-0 pointer-events-none"
              style="background: linear-gradient(135deg, hsl(6 63% 46% / 0.10) 0%, transparent 55%);"
            />
          </div>

          <!-- Floating stat badge -->
          <div class="absolute -bottom-5 -left-7 liquid-glass rounded-2xl px-5 py-4">
            <p class="font-heading font-bold text-2xl text-accent leading-none">+200</p>
            <p class="font-body text-xs text-foreground/50 mt-0.5 uppercase tracking-wider">productos</p>
          </div>

          <!-- Offset frame decoration -->
          <div
            class="absolute -top-3 -right-3 w-full h-full rounded-3xl pointer-events-none -z-10"
            style="border: 1px solid hsl(6 63% 46% / 0.14);"
          />
        </div>
      </div>

    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 md:left-[72px] md:translate-x-0" aria-hidden="true">
    <div class="w-px h-8 overflow-hidden bg-foreground/10 rounded-full">
      <div class="absolute inset-x-0 top-0 h-full bg-foreground/25 rounded-full" style="animation: scroll-line 1.5s infinite;"></div>
    </div>
  </div>
</section>
