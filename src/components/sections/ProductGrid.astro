---
import ProductCard from '../ui/ProductCard.astro'
import SectionHeader from '../ui/SectionHeader.astro'
import type { Product } from '../../lib/products'

interface Props {
  products: Product[]
  heading?: string
  subtext?: string
  viewAllHref?: string
  viewAllLabel?: string
}
const { products, heading, subtext, viewAllHref, viewAllLabel } = Astro.props
---

<section class="bg-background py-12 md:py-28 px-6">
  <div class="max-w-6xl mx-auto">
    {heading && (
      <div class="reveal mb-10">
        <SectionHeader {heading} {subtext} />
      </div>
    )}

    <div class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-4 gap-3 md:gap-6">
      {products.map((product, i) => (
        <ProductCard {product} delay={i * 0.06} />
      ))}
    </div>

    {viewAllHref && (
      <div class="text-center mt-12 reveal">
        <a
          href={viewAllHref}
          class="inline-flex items-center gap-2 liquid-glass rounded-full px-6 py-3 font-body font-semibold text-sm text-foreground hover:shadow-md transition-shadow"
        >
          {viewAllLabel ?? 'Ver todo'}
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M7 7h10v10"/><path d="M7 17 17 7"/></svg>
        </a>
      </div>
    )}
  </div>
</section>
