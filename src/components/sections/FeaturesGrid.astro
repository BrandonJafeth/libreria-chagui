---
import { Image } from 'astro:assets'

import SectionHeader from '../ui/SectionHeader.astro'

export interface FeatureCard {
  icon: string
  title: string
  text: string
  href: string
  iconColor: 'accent' | 'accent-2' | 'accent-3' | 'foreground'
  image?: string
}

interface Props {
  heading: string
  subtext?: string
  cards: FeatureCard[]
}
const { heading, subtext, cards } = Astro.props

// Gradient stops per brand color (to top: dark bottom → transparent top)
const gradients: Record<string, string> = {
  'accent-2':   'hsl(211 50% 20%), hsl(211 50% 36% / 0.45), transparent',
  'foreground': 'hsl(0 0% 8%), hsl(0 0% 17% / 0.45), transparent',
  'accent-3':   'hsl(36 70% 18%), hsl(36 80% 30% / 0.45), transparent',
  'accent':     'hsl(6 63% 22%), hsl(6 63% 40% / 0.45), transparent',
}

// Column spans: 5-col grid, row 1 = 3+2, row 2 = 2+3
const colSpans = [
  'sm:col-span-2 lg:col-span-3',
  'sm:col-span-1 lg:col-span-2',
  'sm:col-span-1 lg:col-span-2',
  'sm:col-span-2 lg:col-span-3',
]
---

<section class="bg-background py-12 md:py-28 px-6">
  <div class="max-w-6xl mx-auto">
    <div class="reveal mb-12">
      <SectionHeader {heading} {subtext} />
    </div>

    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-5 gap-3 auto-rows-[220px] sm:auto-rows-[250px] lg:auto-rows-[305px]">
      {cards.map((card, i) => {
        const gradStops = gradients[card.iconColor] ?? gradients['foreground']
        const span = colSpans[i] ?? ''
        return (
          <a
            href={card.href}
            class={`reveal group relative overflow-hidden rounded-2xl ${span}`}
            style={`--d: ${i * 0.08}s`}
          >
            {/* Background image or solid fallback */}
            {card.image ? (
              <Image
                src={card.image}
                alt=""
                aria-hidden="true"
                class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 ease-out group-hover:scale-[1.05]"
                inferSize={true}
                loading="lazy"
                decoding="async"
              />
            ) : (
              <div class="absolute inset-0 bg-foreground" />
            )}

            {/* Gradient overlay */}
            <div
              class="absolute inset-0"
              style={`background: linear-gradient(to top, ${gradStops})`}
            />

            {/* Hover scrim */}
            <div class="absolute inset-0 bg-black/0 group-hover:bg-black/12 transition-colors duration-300" />

            {/* Content */}
            <div class="absolute bottom-0 left-0 right-0 p-6 md:p-7">
              <h3 class="font-heading font-bold text-white text-xl md:text-2xl leading-tight">
                {card.title}
              </h3>
              <p class="font-body text-sm text-white/60 leading-relaxed mt-1 mb-4">
                {card.text}
              </p>
              <div class="flex items-center gap-1.5 text-[11px] font-body font-semibold uppercase tracking-[0.12em] text-white/70 group-hover:text-white/95 transition-colors duration-200">
                <span>Ver más</span>
                <svg
                  xmlns="http://www.w3.org/2000/svg" width="11" height="11"
                  viewBox="0 0 24 24" fill="none" stroke="currentColor"
                  stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"
                  class="group-hover:translate-x-1 transition-transform duration-200"
                  aria-hidden="true"
                >
                  <path d="m9 18 6-6-6-6"/>
                </svg>
              </div>
            </div>
          </a>
        )
      })}
    </div>
  </div>
</section>
