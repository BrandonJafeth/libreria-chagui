---
import { Image } from 'astro:assets'

import SectionHeader from '../ui/SectionHeader.astro'

interface BentoItem {
  id: string
  nombre: string
  descripcion: string
  icono: string
  accent: string
  tint: string
  imagen?: string
}

interface Props {
  heading?: string
  subtext?: string
  items: BentoItem[]
}

const { heading, subtext, items } = Astro.props

const WA_BASE = 'https://api.whatsapp.com/send?phone=50663595383&text='
function serviceWA(nombre: string) {
  return WA_BASE + encodeURIComponent(`Hola buenas, me interesa el servicio de: ${nombre}`)
}

const FALLBACK = 'https://res.cloudinary.com/daqragn9m/image/upload/v1781889185/servicios-libreriachagui_imu69k.jpg'

const categoryLabel: Record<string, string> = {
  imp: 'Impresión',
  sub: 'Sublimación',
  dis: 'Diseño',
  fot: 'Fotografía',
}
---

<section class="bg-background py-12 md:py-20 px-6">
  <div class="max-w-5xl mx-auto">

    {heading && (
      <div class="reveal mb-2">
        <SectionHeader {heading} {subtext} />
      </div>
    )}

    <div class="reveal mt-10 md:mt-14" style="--d: 0.1s">
      {items.map((item, i) => {
        const img    = item.imagen ?? FALLBACK
        const num    = String(i + 1).padStart(2, '0')
        const prefix = item.id.split('-')[0]
        const cat    = categoryLabel[prefix] ?? ''

        return (
          <a
            href={serviceWA(item.nombre)}
            target="_blank"
            rel="noopener noreferrer"
            class="service-row group relative flex items-center gap-5 md:gap-10
                   py-6 md:py-8 border-b border-foreground/[0.07]
                   transition-colors duration-300
                   hover:bg-foreground/[0.025]
                   -mx-4 px-4 sm:-mx-6 sm:px-6"
            style={`--accent: ${item.accent}`}
          >

            {/* Left accent bar — slides down on hover */}
            <div
              class="accent-bar absolute left-0 top-0 w-[3px] h-full origin-top scale-y-0 group-hover:scale-y-100 transition-transform duration-300 ease-out"
              style={`background: ${item.accent}`}
              aria-hidden="true"
            />

            {/* Number */}
            <span
              class="font-heading font-black leading-none select-none shrink-0
                     text-foreground/[0.09] group-hover:text-foreground/[0.18]
                     transition-colors duration-300
                     text-[2.4rem] sm:text-[3rem] md:text-[3.8rem]
                     w-10 sm:w-14 md:w-20 text-right"
            >
              {num}
            </span>

            {/* Main content */}
            <div class="flex-1 min-w-0">

              {/* Name + category */}
              <div class="flex flex-wrap items-baseline gap-x-3 gap-y-1 mb-1.5">
                <h3
                  class="font-heading font-black text-foreground leading-tight"
                  style="font-size: clamp(1.05rem, 2.4vw, 1.55rem)"
                >
                  {item.nombre}
                </h3>
                <span
                  class="text-[0.52rem] font-bold tracking-[0.24em] uppercase hidden sm:inline shrink-0"
                  style={`color: ${item.accent}`}
                >
                  {cat}
                </span>
              </div>

              {/* Description */}
              <p class="text-foreground/65 text-[0.8rem] sm:text-sm leading-relaxed line-clamp-1 md:line-clamp-2 max-w-lg">
                {item.descripcion}
              </p>

              {/* CTA — slides in on hover */}
              <div
                class="mt-3 inline-flex items-center gap-1.5
                       text-[0.58rem] font-bold tracking-[0.22em] uppercase
                       opacity-0 -translate-x-1 group-hover:opacity-100 group-hover:translate-x-0
                       transition-all duration-300"
                style={`color: ${item.accent}`}
              >
                Consultar por WhatsApp
                <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10"
                     viewBox="0 0 24 24" fill="none" stroke="currentColor"
                     stroke-width="2.5" aria-hidden="true"
                     class="transition-transform duration-300 group-hover:translate-x-0.5">
                  <path d="m9 18 6-6-6-6"/>
                </svg>
              </div>
            </div>

            {/* Image thumbnail — desaturated, wakes on hover */}
            <div class="relative shrink-0 w-[4.5rem] h-[3.5rem] sm:w-28 sm:h-20 md:w-36 md:h-24 overflow-hidden">
              <Image
                src={img}
                alt={item.nombre}
                class="absolute inset-0 w-full h-full object-cover
                       opacity-75 saturate-50 scale-[1.08]
                       sm:opacity-45 sm:saturate-0
                       group-hover:opacity-100 group-hover:saturate-100 group-hover:scale-100
                       transition-all duration-500 ease-out"
                width={640}
                height={425}
                loading="lazy"
                decoding="async"
              />
              {/* Accent tint overlay on hover */}
              <div
                class="absolute inset-0 opacity-0 group-hover:opacity-[0.15] transition-opacity duration-300 pointer-events-none"
                style={`background: ${item.accent}`}
              />
            </div>

            {/* Arrow — desktop */}
            <div
              class="shrink-0 hidden md:flex w-9 h-9 items-center justify-center
                     border border-foreground/8 group-hover:border-foreground/20
                     transition-colors duration-300"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="13" height="13"
                   viewBox="0 0 24 24" fill="none" stroke="currentColor"
                   stroke-width="2" aria-hidden="true"
                   class="text-foreground/50 group-hover:text-foreground/80
                          transition-all duration-300 group-hover:translate-x-0.5">
                <path d="m9 18 6-6-6-6"/>
              </svg>
            </div>

          </a>
        )
      })}
    </div>

    {/* Ver todos los servicios */}
    <div class="reveal mt-8 flex justify-end" style="--d: 0.2s">
      <a
        href="/servicios"
        class="inline-flex items-center gap-2
               text-[0.68rem] font-bold tracking-[0.22em] uppercase
               text-foreground/60 hover:text-foreground/90
               transition-colors duration-200"
      >
        Ver todos los servicios
        <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11"
             viewBox="0 0 24 24" fill="none" stroke="currentColor"
             stroke-width="2.5" aria-hidden="true">
          <path d="M7 7h10v10"/><path d="M7 17 17 7"/>
        </svg>
      </a>
    </div>

  </div>
</section>

<style>
  .service-row:first-of-type {
    border-top: 1px solid rgba(43, 43, 43, 0.07);
  }
</style>
