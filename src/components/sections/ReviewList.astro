---
export interface Review {
  id: string
  author_name: string
  rating: number
  comment: string | null
  created_at: string
}

interface Props {
  reviews: Review[]
}

const { reviews } = Astro.props

function formatDate(dateStr: string): string {
  return new Intl.DateTimeFormat('es-CR', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  }).format(new Date(dateStr))
}
---

{reviews.length === 0 ? (
  <div class="py-10 text-center">
    <p class="font-body text-sm text-foreground/40 uppercase tracking-[0.65px]">Sin reseñas aún</p>
  </div>
) : (
  <div class="space-y-3">
    {reviews.map((review) => (
      <article class="bg-card border-l-2 border-accent px-5 py-4 sm:px-6 sm:py-5">
        <div class="flex items-start justify-between gap-3 flex-wrap">
          <div>
            <span class="font-body font-semibold text-sm text-foreground block">{review.author_name}</span>
            <div
              class="flex gap-0.5 mt-1"
              role="img"
              aria-label={`${review.rating} de 5 estrellas`}
            >
              {[1, 2, 3, 4, 5].map((n) => (
                <span
                  class="text-sm leading-none"
                  style={n <= review.rating ? 'color: hsl(6 63% 46%)' : 'color: hsl(0 0% 80%)'}
                  aria-hidden="true"
                >★</span>
              ))}
            </div>
          </div>
          <time
            class="font-body text-[11px] text-foreground/35 uppercase tracking-[0.4px] shrink-0 mt-0.5"
            datetime={review.created_at}
          >
            {formatDate(review.created_at)}
          </time>
        </div>
        {review.comment && (
          <p class="font-body text-sm text-foreground/60 leading-relaxed mt-3 border-t border-foreground/6 pt-3">
            {review.comment}
          </p>
        )}
      </article>
    ))}
  </div>
)}
