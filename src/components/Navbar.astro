---
import { site } from '../data/site'

const pathname = Astro.url.pathname

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/'
  return pathname.startsWith(href)
}
---

<header id="site-header" class="fixed top-4 left-0 right-0 z-50 px-4 lg:px-6">
  <div class="max-w-7xl mx-auto">
    <!-- Desktop navbar -->
    <div
      id="navbar-inner"
      class="liquid-glass rounded-full px-1.5 py-1.5 flex items-center justify-between transition-shadow duration-300"
    >
      <!-- Logo -->
      <a href="/" class="flex items-center gap-2 pl-2 shrink-0">
        <img
          src={site.logo}
          alt={site.name}
          height="40"
          class="h-10 w-auto object-contain rounded"
          loading="eager"
        />
      </a>

      <!-- Desktop links -->
      <nav class="hidden md:flex items-center gap-0.5" aria-label="Navegación principal">
        {site.nav.map((link) => (
          <a
            href={link.href}
            class={`px-4 py-2 rounded-full text-xs font-body font-medium tracking-wide transition-colors ${
              isActive(link.href)
                ? 'text-foreground bg-foreground/6'
                : 'text-foreground/60 hover:text-foreground'
            }`}
          >
            {link.label}
          </a>
        ))}
      </nav>

      <!-- CTA + mobile toggle -->
      <div class="flex items-center gap-2">
        <a
          href={site.cta.href}
          target="_blank"
          rel="noopener noreferrer"
          class="bg-accent text-white rounded-full px-4 py-2 font-body font-semibold text-xs tracking-wider uppercase inline-flex items-center gap-1.5 hover:opacity-90 transition-opacity"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
            <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
          </svg>
          {site.cta.label}
        </a>

        <button
          id="menu-toggle"
          class="md:hidden liquid-glass-strong rounded-full w-9 h-9 flex items-center justify-center text-foreground/70 hover:text-foreground transition-colors"
          aria-label="Abrir menú"
          aria-expanded="false"
        >
          <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="18" y2="18"/>
          </svg>
          <svg id="icon-close" class="hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M18 6 6 18"/><path d="m6 6 12 12"/>
          </svg>
        </button>
      </div>
    </div>

    <!-- Mobile menu -->
    <div
      id="mobile-menu"
      class="hidden md:hidden liquid-glass-strong rounded-3xl mx-0 mt-2 p-6"
      role="dialog"
      aria-label="Menú móvil"
    >
      <nav class="flex flex-col gap-1" aria-label="Navegación móvil">
        {site.nav.map((link) => (
          <a
            href={link.href}
            class={`px-4 py-3 rounded-2xl text-base font-body font-medium transition-colors ${
              isActive(link.href)
                ? 'text-foreground bg-foreground/6'
                : 'text-foreground/60 hover:text-foreground hover:bg-foreground/4'
            }`}
          >
            {link.label}
          </a>
        ))}
        <div class="mt-4 pt-4 border-t border-foreground/8">
          <a
            href={site.cta.href}
            target="_blank"
            rel="noopener noreferrer"
            class="bg-accent text-white rounded-full px-5 py-3 font-body font-semibold text-sm uppercase tracking-wider flex items-center justify-center gap-2 hover:opacity-90 transition-opacity"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/>
            </svg>
            Consultar por WhatsApp
          </a>
        </div>
      </nav>
    </div>
  </div>
</header>

<script>
  const toggle = document.getElementById('menu-toggle')!
  const menu = document.getElementById('mobile-menu')!
  const iconMenu = document.getElementById('icon-menu')!
  const iconClose = document.getElementById('icon-close')!
  const navbar = document.getElementById('navbar-inner')!

  toggle.addEventListener('click', () => {
    const open = menu.classList.toggle('hidden') === false
    toggle.setAttribute('aria-expanded', String(open))
    iconMenu.classList.toggle('hidden', open)
    iconClose.classList.toggle('hidden', !open)
  })

  // Close on link click
  menu.querySelectorAll('a').forEach((a) => {
    a.addEventListener('click', () => {
      menu.classList.add('hidden')
      toggle.setAttribute('aria-expanded', 'false')
      iconMenu.classList.remove('hidden')
      iconClose.classList.add('hidden')
    })
  })

  // Shadow on scroll
  window.addEventListener('scroll', () => {
    if (window.scrollY > 40) {
      navbar.style.boxShadow = '0 4px 24px rgba(0,0,0,.10), 0 1px 6px rgba(0,0,0,.06)'
    } else {
      navbar.style.boxShadow = ''
    }
  }, { passive: true })
</script>
