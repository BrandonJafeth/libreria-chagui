---
import Navbar from '../components/Navbar.astro'
import Footer from '../components/Footer.astro'
import '../styles/global.css'
import { site } from '../data/site'

interface Props {
  title: string
  description?: string
  ogImage?: string
  noIndex?: boolean
  keywords?: string
}

const {
  title,
  description = site.description,
  ogImage,
  noIndex = false,
  keywords,
} = Astro.props

const fullTitle = title === 'Inicio'
  ? `${site.name} — Librería y Bazar en Hatillo, San José`
  : `${site.name} | ${title}`

const canonicalURL = new URL(Astro.url.pathname, Astro.site ?? 'https://libreriachagui.com')
const ogImageUrl = ogImage ?? `${site.domain}/og-image.jpg`
const isHome = Astro.url.pathname === '/'

/* ── LocalBusiness + BookStore schema (sitewide) ── */
const localBusinessSchema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'BookStore'],
  name: site.name,
  description: 'Librería y bazar en Hatillo, San José, Costa Rica. Útiles escolares, oficina, tecnología. Servicios de impresión, sublimación, diseño y fotografía.',
  url: site.domain,
  telephone: site.contact.phone,
  image: site.logo,
  logo: site.logo,
  address: {
    '@type': 'PostalAddress',
    streetAddress: 'Hatillo, de la rotonda 75 metros norte, mano derecha, diagonal al C.C. Plaza América',
    addressLocality: 'Hatillo',
    addressRegion: 'San José',
    postalCode: '10801',
    addressCountry: 'CR',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: 9.911819990189127,
    longitude: -84.10121512520762,
  },
  hasMap: site.contact.mapsUrl,
  priceRange: '₡',
  currenciesAccepted: 'CRC',
  areaServed: { '@type': 'City', name: 'San José' },
  sameAs: [site.social.instagram, site.social.facebook, site.social.tiktok],
}

/* ── WebSite schema with Sitelinks Searchbox (home only) ── */
const websiteSchema = {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  name: site.name,
  url: site.domain,
  potentialAction: {
    '@type': 'SearchAction',
    target: {
      '@type': 'EntryPoint',
      urlTemplate: `${site.domain}/catalogo?q={search_term_string}`,
    },
    'query-input': 'required name=search_term_string',
  },
}

/* ── BreadcrumbList schema (inner pages) ── */
const breadcrumbSchema = !isHome ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Inicio', item: site.domain },
    { '@type': 'ListItem', position: 2, name: title,   item: canonicalURL.toString() },
  ],
} : null
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {noIndex && <meta name="robots" content="noindex,nofollow" />}

    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    {keywords && <meta name="keywords" content={keywords} />}
    <link rel="canonical" href={canonicalURL} />

    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImageUrl} />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="es_CR" />
    <meta property="og:site_name" content={site.name} />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImageUrl} />

    <meta name="geo.region" content="CR-SJ" />
    <meta name="geo.placename" content="Hatillo, San José, Costa Rica" />
    <meta name="geo.position" content="9.911819;-84.101215" />
    <meta name="ICBM" content="9.911819, -84.101215" />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- LocalBusiness + BookStore schema (todas las páginas) -->
    <script is:inline type="application/ld+json" set:html={JSON.stringify(localBusinessSchema)} />

    {isHome && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
    )}

    {breadcrumbSchema && (
      <script is:inline type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
    )}
  </head>
  <body class="bg-background text-foreground font-body antialiased">
    <Navbar />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Scroll to top (bottom) -->
    <button
      id="scroll-top"
      aria-label="Volver arriba"
      class="fixed bottom-6 right-6 z-50 w-10 h-10 rounded-full flex items-center justify-center text-white/50 hover:text-white transition-all duration-200 opacity-0 invisible"
      style="background:#252525; border:1px solid #3a3a3a;"
    >
      <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
        <path d="m18 15-6-6-6 6"/>
      </svg>
    </button>

    <!-- Floating WhatsApp button (above scroll-to-top) -->
    <a
      href={site.contact.whatsappBase}
      target="_blank"
      rel="noopener noreferrer"
      aria-label="Contactar por WhatsApp"
      class="fixed bottom-20 right-6 z-50 w-14 h-14 hover:scale-110 active:scale-95 transition-transform duration-150 drop-shadow-xl"
    >
      <svg viewBox="0 0 56 56" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">
        <circle cx="28" cy="28" r="28" fill="#25D366"/>
        <path fill="#ffffff" d="M38.03 17.97A14.4 14.4 0 0 0 28 14c-7.97 0-14.45 6.48-14.45 14.44 0 2.55.67 5.03 1.93 7.22L13.5 42.5l7.04-1.85a14.44 14.44 0 0 0 6.9 1.76h.01c7.96 0 14.44-6.48 14.44-14.44 0-3.86-1.5-7.48-4.86-10.01zm-10.03 22.2h-.01a12 12 0 0 1-6.12-1.68l-.44-.26-4.55 1.19 1.22-4.43-.28-.46a11.95 11.95 0 0 1-1.84-6.4c0-6.61 5.38-11.98 12-11.98a11.93 11.93 0 0 1 11.99 11.99c0 6.61-5.38 11.99-11.97 11.99v.04zm6.58-8.97c-.36-.18-2.13-1.05-2.46-1.17-.33-.12-.57-.18-.81.18-.24.36-.93 1.17-1.14 1.41-.21.24-.42.27-.78.09-.36-.18-1.52-.56-2.9-1.79-1.07-.95-1.8-2.13-2.01-2.49-.21-.36-.02-.56.16-.73.16-.16.36-.42.54-.63.18-.21.24-.36.36-.6.12-.24.06-.45-.03-.63-.09-.18-.81-1.95-1.11-2.67-.29-.7-.59-.6-.81-.61-.21-.01-.45-.01-.69-.01-.24 0-.63.09-.96.45-.33.36-1.26 1.23-1.26 3 0 1.77 1.29 3.48 1.47 3.72.18.24 2.55 3.9 6.18 5.46.86.37 1.53.59 2.05.76.86.27 1.65.23 2.27.14.69-.1 2.13-.87 2.43-1.71.3-.84.3-1.56.21-1.71-.09-.15-.33-.24-.69-.42z"/>
      </svg>
    </a>

    <!-- Custom cursor dot (desktop only) -->
    <div id="cursor-dot" aria-hidden="true"></div>

    <script>
      const io = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add('visible')
              io.unobserve(e.target)
            }
          }
        },
        { rootMargin: '0px 0px -80px 0px' }
      )
      document.querySelectorAll('.reveal').forEach((el) => io.observe(el))

      const scrollBtn = document.getElementById('scroll-top')!
      window.addEventListener('scroll', () => {
        if (window.scrollY > 500) {
          scrollBtn.classList.remove('opacity-0', 'invisible')
          scrollBtn.classList.add('opacity-100')
        } else {
          scrollBtn.classList.add('opacity-0', 'invisible')
          scrollBtn.classList.remove('opacity-100')
        }
      }, { passive: true })
      scrollBtn.addEventListener('click', () => window.scrollTo({ top: 0, behavior: 'smooth' }))

      // Custom cursor ring — smooth lerp follow, pointer:fine only
      const dot = document.getElementById('cursor-dot')
      if (dot && window.matchMedia('(pointer: fine)').matches) {
        let tx = -200, ty = -200
        let cx = -200, cy = -200

        document.addEventListener('mousemove', (e) => {
          tx = e.clientX
          ty = e.clientY
        }, { passive: true })
        document.addEventListener('mouseleave', () => { dot.style.opacity = '0' })
        document.addEventListener('mouseenter', () => { dot.style.opacity = '1' })

        ;(function loop() {
          cx += (tx - cx) * 0.1
          cy += (ty - cy) * 0.1
          dot.style.transform = `translate(${cx}px, ${cy}px)`
          requestAnimationFrame(loop)
        })()

        const grow = () => dot.classList.add('cursor-grow')
        const shrink = () => dot.classList.remove('cursor-grow')
        document.querySelectorAll('a, button, [role="button"], input, select, textarea, label').forEach(el => {
          el.addEventListener('mouseenter', grow)
          el.addEventListener('mouseleave', shrink)
        })
      }
    </script>
  </body>
</html>
